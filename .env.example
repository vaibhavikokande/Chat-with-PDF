# ─────────────────────────────────────────────────────────────────────────────
#  Chat with your PDF — environment variables
#  Copy this file to ".env" and fill in at least ONE provider key.
# ─────────────────────────────────────────────────────────────────────────────

# ── Option A: Anthropic / Claude (paid) ──────────────────────────────────────
#  Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# ── Option B: Groq / Llama 3.3 (FREE — no credit card needed) ───────────────
#  1. Sign up free at: https://console.groq.com/
#  2. Go to  API Keys  →  Create API Key
#  3. Paste it below
GROQ_API_KEY=your_groq_key_here

# ── Server port (optional) ───────────────────────────────────────────────────
PORT=5000
